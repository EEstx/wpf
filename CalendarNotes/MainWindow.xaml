<Window x:Class="CalendarNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CalendarNotes.ViewModels"
        Title="Календарь с заметками" Height="500" Width="600" WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Навигационные кнопки -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Content="Предыдущий месяц" Command="{Binding PrevMonthCommand}" Padding="15,5" FontSize="14"/>
            
            <TextBlock Grid.Column="1" Text="{Binding MonthYear}" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            
            <Button Grid.Column="2" Content="Следующий месяц" Command="{Binding NextMonthCommand}" Padding="15,5" FontSize="14"/>
        </Grid>
        
        <!-- Дни недели -->
        <UniformGrid Grid.Row="1" Columns="7" Margin="0,0,0,5">
            <TextBlock Text="Пн" TextAlignment="Center" FontWeight="Bold" FontSize="14"/>
            <TextBlock Text="Вт" TextAlignment="Center" FontWeight="Bold" FontSize="14"/>
            <TextBlock Text="Ср" TextAlignment="Center" FontWeight="Bold" FontSize="14"/>
            <TextBlock Text="Чт" TextAlignment="Center" FontWeight="Bold" FontSize="14"/>
            <TextBlock Text="Пт" TextAlignment="Center" FontWeight="Bold" FontSize="14"/>
            <TextBlock Text="Сб" TextAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="DarkRed"/>
            <TextBlock Text="Вс" TextAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="DarkRed"/>
        </UniformGrid>
        
        <!-- Таблица с ячейками для отображения дат -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding CalendarDays}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7" Rows="6"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding DataContext.DayClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                            CommandParameter="{Binding}" Margin="2">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="FontSize" Value="16"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="LightGray"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                
                                <Style.Triggers>
                                    <!-- Ячейки из другого месяца -->
                                    <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                        <Setter Property="Foreground" Value="Gray"/>
                                    </DataTrigger>
                                    
                                    <!-- Есть заметки -->
                                    <DataTrigger Binding="{Binding HasNotes}" Value="True">
                                        <Setter Property="BorderBrush" Value="Orange"/>
                                        <Setter Property="BorderThickness" Value="3"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <!-- Содержимое кнопки (число) -->
                        <TextBlock Text="{Binding DayNumber}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
