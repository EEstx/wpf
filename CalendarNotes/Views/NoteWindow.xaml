<Window x:Class="CalendarNotes.Views.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="350" Width="300" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock FontWeight="Bold" FontSize="16" Text="Список заметок:" Margin="0,0,0,10"/>
        
        <ListBox Grid.Row="1" ItemsSource="{Binding DayNotes}" Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="Удалить" Foreground="Red" 
                                Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                CommandParameter="{Binding}" Padding="5,2"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Новая заметка:"/>
            <TextBox Text="{Binding NewNoteText, UpdateSourceTrigger=PropertyChanged}" 
                     TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,5"/>
            <Button Content="Добавить заметку" Command="{Binding AddNoteCommand}" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>