<Window x:Class="DeliveryService.Views.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заказа" Height="350" Width="350" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="15">
        <TextBlock Text="Адрес:" />
        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

        <TextBlock Text="Статус:" />
        <ComboBox SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10">
            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Ожидает</System:String>
            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">В пути</System:String>
            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Доставлен</System:String>
        </ComboBox>

        <TextBlock Text="Курьер (ФИО):" />
        <TextBox Text="{Binding CourierName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" ToolTip="Введите существующего или нового курьера" />

        <TextBlock Text="Транспорт (если новый):" />
        <ComboBox SelectedItem="{Binding CourierTransport, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10">
            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Пешком</System:String>
            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Велосипед</System:String>
            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Авто</System:String>
        </ComboBox>

        <Button Content="Сохранить" Command="{Binding SaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Width="100" />
    </StackPanel>
</Window>