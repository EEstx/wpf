<Window x:Class="DeliveryService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Служба доставки (Заказы)" Height="450" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Заказы">
                <MenuItem Header="Добавить" Command="{Binding AddCommand}" />
                <MenuItem Header="Редактировать" Command="{Binding EditCommand}" />
                <MenuItem Header="Удалить" Command="{Binding DeleteCommand}" />
                <Separator />
                <MenuItem Header="Экспорт в CSV" Command="{Binding ExportCommand}" />
            </MenuItem>
        </Menu>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0" />
            <TextBox Width="150" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,15,0" />

            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,5,0" />
            <ComboBox Width="100" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SortBy}" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="&lt;&lt;" Command="{Binding PrevPageCommand}" Width="40" Margin="0,0,10,0"/>
            <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center"/>
            <TextBlock Text=" из " VerticalAlignment="Center"/>
            <TextBlock Text="{Binding TotalPages}" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button Content="&gt;&gt;" Command="{Binding NextPageCommand}" Width="40" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Добавить" Command="{Binding AddCommand}" />
                    <MenuItem Header="Редактировать" Command="{Binding EditCommand}" />
                    <MenuItem Header="Удалить" Command="{Binding DeleteCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding OrderId}" />
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="*" />
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" />
                <DataGridTextColumn Header="Курьер" Binding="{Binding CourierName}" />
                <DataGridTextColumn Header="Транспорт" Binding="{Binding CourierTransport}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
